# Groq API key — create one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Postgres connection string (or use MySQL with mysql+pymysql://...)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hcp_crm

# Set to sqlite for zero-config local run:
# DATABASE_URL=sqlite:///./hcp_crm.db
